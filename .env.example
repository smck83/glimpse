# GitHub personal access token
# Required scopes: Contents (read/write) on your target repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your github.io repo in owner/repo format
GITHUB_REPO=yourusername/yourusername.github.io

# Branch to push to (usually main or master)
GITHUB_BRANCH=main

# Subfolder inside your repo where glimpse files will be stored
# Files land at yourusername.github.io/glimpse/slug.html
VAULT_SUBDIR=glimpse

# Base URL for your GitHub Pages site (no trailing slash)
PAGES_BASE_URL=https://yourusername.github.io

# Secret key required to use the publish form
# Generate one: openssl rand -base64 24
APP_API_KEY=change-me-to-something-strong

# SQLite DB path inside the container (don't change unless you know why)
DB_PATH=/data/glimpse.db
