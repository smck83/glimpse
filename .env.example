# ---- Required ----
APP_API_KEY=change-me-strong-key
GLIMPSE_PUBLIC_URL=https://glimpseadmin.yourdomain.com
# Origin of your vault/recipient pages (for CORS) - e.g. if files served from a different domain
VAULT_ORIGIN=https://glimpsevault.yourdomain.com

# ---- Storage backend: github | local | r2 (default: local) ----
STORAGE_BACKEND=local

# ---- GitHub backend (required if STORAGE_BACKEND=github) ----
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=yourusername/yourrepo
GITHUB_BRANCH=main
VAULT_SUBDIR=vault
PAGES_BASE_URL=https://yourusername.github.io/yourrepo

# ---- Local backend ----
LOCAL_VAULT_DIR=/data/vault

# ---- Cloudflare R2 backend (required if STORAGE_BACKEND=r2) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ---- General ----
DB_PATH=/data/glimpse.db
MAX_FILE_SIZE_MB=50

# ---- Security / brute force protection ----
# Set to true if running behind Cloudflare (reads CF-Connecting-IP header for real IP)
TRUSTED_PROXY_MODE=true
# Max failed login attempts before lockout
BF_MAX_ATTEMPTS=10
# Window in minutes to count failed attempts
BF_WINDOW_MINUTES=15
# Lockout duration in minutes after threshold reached
BF_LOCKOUT_MINUTES=30
# Number of lockouts before hard (24h) lockout kicks in
BF_LOCKOUT_THRESHOLD=3
# Hard lockout duration in minutes (default 1440 = 24 hours)
BF_HARD_LOCKOUT_MINUTES=1440
